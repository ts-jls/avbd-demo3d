{
  "name": "avbd-three-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "server:gpu": "node scripts/start-gpu-server.mjs",
    "smoke:samples": "node scripts/sample-smoke.mjs",
    "smoke:bridge": "node scripts/bridge-smoke.mjs",
    "smoke:bridge:binary": "node scripts/bridge-smoke.mjs --binary true",
    "smoke:bridge:backend": "node scripts/bridge-smoke.mjs --command physicsBackend --value webgpu-avbd --expect-status-contains \"WebGPU AVBD\" --timeout 12000",
    "smoke:server:gpu": "node scripts/gpu-server-smoke.mjs",
    "smoke:contracts": "node scripts/viewer-contract-smoke.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "smoke:browser:native": "node scripts/browser-smoke.mjs --expect-native true",
    "benchmark:headless": "node scripts/headless-benchmark.mjs",
    "checkpoint:gpu-playable": "node scripts/gpu-checkpoint.mjs",
    "benchmark:gpu-avbd-5k": "node scripts/headless-benchmark.mjs --exe C:\\code\\avbd-demo3d\\build-webgpu-dawn-nmake3\\avbd_headless_server.exe --frames 600 --warmup-frames 5 --stream-frames 0 --scenes \"Sphere Pour 5000 on Cylinders\" --physics-backend webgpu-avbd --assert-physics-avg-under 35 --assert-no-webgpu-fallbacks true --assert-max-ground-penetration 0.05 --assert-final-max-speed-max 25 --assert-final-dynamic-max-height-max 35",
    "benchmark:gpu-avbd-softbody": "node scripts/headless-benchmark.mjs --exe C:\\code\\avbd-demo3d\\build-webgpu-dawn-nmake3\\avbd_headless_server.exe --frames 240 --warmup-frames 5 --stream-frames 0 --scenes \"Soft Body 8x8x8\" --physics-backend webgpu-avbd --assert-physics-avg-under 45 --assert-final-max-speed-max 100 --assert-final-dynamic-max-height-min 2.0 --assert-max-ground-body-penetration 0.05",
    "benchmark:gpu-avbd-compare": "node scripts/native-backend-compare.mjs --exe C:\\code\\avbd-demo3d\\build-webgpu-dawn-nmake3\\avbd_headless_server.exe --frames 120 --scenes \"Pyramid,Rope,Soft Body\" --backend webgpu-avbd --assert-max-position-error 0.05 --assert-rms-position-error 0.02 --assert-max-rotation-error 0.05 --assert-no-webgpu-fallbacks true"
  },
  "dependencies": {
    "three": "^0.165.0",
    "vite": "^5.4.19"
  },
  "devDependencies": {}
}
